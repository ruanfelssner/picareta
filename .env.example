NUXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB
NUXT_MONGO_URI=mongodb://root:root@localhost:27017/
NUXT_MONGO_DB_NAME=picareta
MONGODB_URI=mongodb://root:root@localhost:27017/picareta?authSource=admin

# Redis (para filas/cache)
REDIS_HOST=localhost
REDIS_PORT=16379

# Flask Service
FLASK_PORT=5000
FLASK_DEBUG=False
NUXT_FLASK_BASE_URL=http://127.0.0.1:5000
NUXT_FLASK_TIMEOUT_MS=120000
PLATE_OCR_MAX_SIDE=1440
PLATE_OCR_MAX_FALLBACK_REGIONS=4
PLATE_OCR_STRONG_CONFIDENCE=0.72
PLATE_OCR_UPSCALE_MAX_SIDE=900
PLATE_OCR_PREPROCESS_MAX_PIXELS=1400000
PLATE_OCR_PRELOAD_MODELS=false
PLATE_OCR_AMBIGUOUS_DELTA=0.06
PLATE_OCR_ZERO_PRIORITY_DELTA=0.05

# Integracao Placa FIPE (https://api.placafipe.com.br)
NUXT_PLACA_FIPE_BASE_URL=https://api.placafipe.com.br
NUXT_PLACA_FIPE_TOKEN=
NUXT_PLACA_FIPE_MOCK=true
# Endpoints usados no backend:
# - POST /getplacafipe
# - POST /getplaca (fallback)
# - POST /getquotas (nao consome quota)
# Para usar a API real, altere NUXT_PLACA_FIPE_MOCK=false

# Node Environment
NODE_ENV=development
