NUXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB
NUXT_MONGO_URI=mongodb://root:root@localhost:27017/
NUXT_MONGO_DB_NAME=picareta
MONGODB_URI=mongodb://root:root@localhost:27017/picareta?authSource=admin

# Redis (para filas/cache)
REDIS_HOST=localhost
REDIS_PORT=16379

# Flask Service
FLASK_PORT=5000
FLASK_DEBUG=False
NUXT_FLASK_BASE_URL=http://127.0.0.1:5000
NUXT_FLASK_TIMEOUT_MS=120000

# Opcional para integracao real Placa + FIPE
NUXT_PLACA_FIPE_BASE_URL=
NUXT_PLACA_FIPE_TOKEN=
NUXT_PLACA_FIPE_LOOKUP_PATH=/lookup
NUXT_PLACA_FIPE_LOOKUP_METHOD=POST
NUXT_PLACA_FIPE_REQUEST_PLATE_FIELD=placa
NUXT_PLACA_FIPE_DEVICE_TOKEN=
NUXT_PLACA_FIPE_USER_AGENT=Thunder Client (https://www.thunderclient.com)
NUXT_PLACA_FIPE_TIMEOUT_MS=8000
NUXT_PLACA_FIPE_LOOKUP_STRATEGY=scrape-first
# Opcional para scraping quando Cloudflare bloquear: valor do cookie cf_clearance
NUXT_PLACA_FIPE_CF_CLEARANCE=

# Node Environment
NODE_ENV=development
